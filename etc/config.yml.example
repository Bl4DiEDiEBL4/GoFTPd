# ============================================================================
# GoFTPd Configuration
# ============================================================================
#
# ARCHITECTURE (master/slave like drftpd):
#
#   master  - FTP server clients connect to. No local files. Routes transfers
#             to slaves via VFS. Zipscript runs here via VFS metadata.
#
#   slave   - Storage node. Connects to master, serves files on demand.
#             Multiple slaves supported across different machines.
#
# ============================================================================

# ============================================================================
# SERVER IDENTITY
# ============================================================================
sitename_long: "GoFTPd"
sitename_short: "GoFTPd"
version: "1.0.0"
email: "admin@example.com"

# ============================================================================
# NETWORK
# ============================================================================
listen_port: 21212
public_ip: "1.2.3.4"
pasv_min: 25000
pasv_max: 30000

# ============================================================================
# MODE: master or slave
# ============================================================================
mode: master

# ============================================================================
# MASTER SETTINGS
# ============================================================================
master:
  listen_host: "0.0.0.0"
  control_port: 1099
  heartbeat_timeout: 60
  index_cache_ttl: 300

# ============================================================================
# SLAVE SETTINGS
# ============================================================================
slave:
  name: "SLAVE1"
  master_host: "127.0.0.1"
  master_port: 1099
  roots:
    - "/data/site"
  pasv_port_min: 30000
  pasv_port_max: 35000
  bind_ip: ""
  timeout: 60

# ============================================================================
# PATHS
# ============================================================================
storage_path: ./site
acl_base_path: "/site"
passwd_file: "etc/passwd"
shell_path: "/bin/false"
msg_path: "etc/msgs"

# ============================================================================
# TLS/SSL
# ============================================================================
tls_enabled: true
tls_cert: ./etc/server.crt
tls_key: ./etc/server.key

# ============================================================================
# FEATURES
# ============================================================================
creditcheck: true
free_space_mb: 2048
max_connections: 300

# ============================================================================
# DIRECTORY LISTING
# ============================================================================
show_diz:
  .message: "*"
  .imdb: "*"
show_symlinks: true

# ============================================================================
# ZIPSCRIPT (built-in via VFS, like drftpd)
# ============================================================================
# Race stats, status bar, and missing files are virtual LIST entries.
# Nothing is written to slave disk. SFV cached in master VFS memory.
incomplete_indicator: "[incomplete]-%0"

# ============================================================================
# NUKE
# ============================================================================
nuke_max_multiplier: 50
nukedir_style: "[NUKED]-%N"

# ============================================================================
# PLUGINS
# ============================================================================
plugins:
  imdb:
    enabled: true
  tvmaze:
    enabled: true

# ============================================================================
# DUPE DETECTION
# ============================================================================
xdupe_enabled: true
xdupe_db_path: "./logs/xdupe.db"

# ============================================================================
# DEBUG
# ============================================================================
debug: true
